upstream ssh {
  server localhost:22;
}

upstream ovpn {
  server localhost:1194;
}

server {
  js_path    "/usr/local/opt/nginx/njs";
  js_import  ssh from ssh_proxy.js;
  js_var     $x_ssh_detect;
  js_set     $x_http_upstream ssh.upstream;
  listen     [::]:80 reuseport;
  js_preread ssh.detect;
  proxy_pass $x_http_upstream;
}