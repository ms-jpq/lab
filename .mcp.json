{
  "mcpServers": {
    "grafana": {
      "command": "mcp-grafana",
      "env": {
        "GRAFANA_EXTRA_HEADERS": "{\"Authorization\": \"Basic ${GRAFANA_TOKEN}\"}",
        "GRAFANA_URL": "http://freenas.enp1s0.pfsense.home.arpa:8080/grafana"
      }
    },
    "kubernetes": {
      "headers": {
        "Authorization": "Basic ${K8S_TOKEN}"
      },
      "type": "http",
      "url": "https://k8s.mcp.${MCP_DOMAIN}/mcp"
    }
  }
}
