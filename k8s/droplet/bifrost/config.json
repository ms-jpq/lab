{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "allow_direct_keys": true
  },
  "config_store": {
    "config": {
      "db_name": "kompsed-bifrost",
      "host": "pg.kompsed-bifrost.svc.cluster.local",
      "password": "kompsed-bifrost",
      "port": "5432",
      "ssl_mode": "disable",
      "user": "kompsed-bifrost"
    },
    "enabled": true,
    "type": "postgres"
  },
  "governance": {
    "auth_config": {
      "admin_password": "env.BIFROST_ADMIN_PASSWORD",
      "admin_username": "env.BIFROST_ADMIN_USERNAME",
      "disable_auth_on_inference": true,
      "is_enabled": true
    }
  },
  "logs_store": {
    "config": {
      "db_name": "kompsed-bifrost",
      "host": "pg.kompsed-bifrost.svc.cluster.local",
      "password": "kompsed-bifrost",
      "port": "5432",
      "ssl_mode": "disable",
      "user": "kompsed-bifrost"
    },
    "enabled": true,
    "type": "postgres"
  },
  "plugins": [
    {
      "config": {
        "collector_url": "http://langfuse-web.kompsed-langfuse.svc.cluster.local:3000/api/public/otel/v1/traces",
        "headers": {
          "Authorization": "env.LANGFUSE_AUTH"
        },
        "protocol": "http",
        "service_name": "bifrost",
        "trace_type": "genai_extension"
      },
      "enabled": true,
      "name": "otel"
    }
  ]
}
