{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "allow_direct_keys": true
  },
  "governance": {
    "auth_config": {
      "admin_password": "env.BIFROST_ADMIN_PASSWORD",
      "admin_username": "env.BIFROST_ADMIN_USERNAME",
      "disable_auth_on_inference": true,
      "is_enabled": true
    }
  },
  "logs_store": {
    "config": {
      "db_name": "kompsed-bifrost",
      "host": "pg.kompsed-bifrost.svc.cluster.local",
      "password": "kompsed-bifrost",
      "port": "5432",
      "ssl_mode": "disable",
      "user": "kompsed-bifrost"
    },
    "enabled": true,
    "type": "postgres"
  },
  "mcp": {
    "client_configs": [
      {
        "connection_string": "http://searx.kompsed-mcp.svc.cluster.local:8080/mcp",
        "connection_type": "http",
        "name": "searx"
      },
      {
        "connection_string": "http://crawl4ai.kompsed-crawl4ai.svc.cluster.local:11235/mcp/sse",
        "connection_type": "sse",
        "name": "crawl4ai"
      },
      {
        "connection_string": "http://playwright.kompsed-mcp.svc.cluster.local:8080/mcp",
        "connection_type": "http",
        "name": "playwright"
      }
    ]
  },
  "plugins": [
    {
      "config": {
        "collector_url": "http://langfuse-web.kompsed-langfuse.svc.cluster.local:3000/api/public/otel/v1/traces",
        "headers": {
          "Authorization": "env.LANGFUSE_AUTH"
        },
        "protocol": "http",
        "service_name": "bifrost",
        "trace_type": "genai_extension"
      },
      "enabled": true,
      "name": "otel"
    }
  ],
  "providers": {
    "anthropic": {
      "proxy_config": {
        "type": "socks5",
        "url": "socks5://proxy.kompsed-hostproxy.svc.cluster.local:1080"
      }
    },
    "openai": {
      "proxy_config": {
        "type": "socks5",
        "url": "socks5://proxy.kompsed-hostproxy.svc.cluster.local:1080"
      }
    },
    "openrouter": {
      "proxy_config": {
        "type": "socks5",
        "url": "socks5://proxy.kompsed-hostproxy.svc.cluster.local:1080"
      }
    }
  }
}
