DOMAIN=m5_assert([ENV_DOMAIN])
ENCRYPTION_KEY=m4_substr(m5_assert([ENV_RAND_HEX]), 0, 64)
NEXTAUTH_SECRET=m5_assert([ENV_RAND_HEX])
SALT=m4_substr(m5_assert([ENV_RAND_HEX]), 0, 16)
LANGFUSE_INIT_USER_EMAIL=m5_assert([ENV_MINIFLUX_USERNAME])
LANGFUSE_INIT_USER_PASSWORD=m5_assert([ENV_MINIFLUX_PASSWORD])

LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=m5_assert([ENV_LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID])
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=m5_assert([ENV_LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY])
